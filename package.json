{
  "name": "@raicampos/query-toolkit",
  "version": "1.1.3",
  "description": "Pacote de ferramentas para queries. RSQL, filtros, paginação e ordenação.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./common": "./dist/common/index.js",
    "./converters": "./dist/converters/index.js",
    "./mappers": "./dist/mappers/index.js",
    "./query-operator": "./dist/query-operator/index.js",
    "./rsql-parse": "./dist/rsql-parse/index.js",
    "./sql-builder": "./dist/sql-builder/index.js",
    "./types": "./dist/types/index.js"
  },
  "scripts": {
    "version": "npm version patch",
    "build": "tsc",
    "prebuild": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "prepare": "husky",
    "commit": "cz"
  },
  "keywords": [
    "query",
    "rsql",
    "filter",
    "pagination",
    "sort",
    "sql",
    "builder"
  ],
  "author": "Raí Campos <rai.campos@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Raicamposs/query-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/Raicamposs/query-toolkit/issues"
  },
  "homepage": "https://github.com/Raicamposs/query-toolkit#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/node": "^24.0.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^3.2.4",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@raicampos/toolkit": "^1.1.1",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
